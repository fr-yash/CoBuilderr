# Frontend Environment Variables
# Copy this file to .env.local for local development
# For production, set these variables in your hosting platform (e.g., Render)

# API URL - Set this to your backend URL (NO trailing slash, include scheme)
VITE_API_URL=http://localhost:3001

# For production on Render, set this in the Render dashboard (Environment tab), e.g.:
# VITE_API_URL=https://cobuilderr-backend.onrender.com